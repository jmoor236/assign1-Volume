#include <iostream>
using namespace std; 

int main () {
  int numTeaspoons;
  cin >> numTeaspoons;
  
  cout << "Teaspoons: ";
  cout << numTeaspoons << endl;

  int numQuarts = numTeaspoons / 192;
  cout << "Quarts: ";
  cout << numQuarts << endl;

  int numCups = numTeaspoons / 48;
  cout << "Cups: ";
  cout << numCups << endl;

  int numTablespoons = numTeaspoons / 3;
  cout << "Tablespoons: ";
  cout << numTablespoons << endl;

  cout << "Teaspoons: ";
  cout << numTeaspoons << endl;
}
